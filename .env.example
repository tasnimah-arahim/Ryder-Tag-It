# Copy to .env and fill in real values. Never commit .env.
# ── ServiceNow ────────────────────────────────────────────────────────────────
SN_INSTANCE_URL=https://your-instance.service-now.com
SN_USER=your-servicenow-username
SN_PASSWORD=your-servicenow-password

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3000

# ── WebAuthn Relying Party ────────────────────────────────────────────────────
# RP_ID    : effective domain only (no protocol, no port)
#            Must match the domain the kiosk browser navigates to.
# ORIGIN   : full origin as seen by the browser (protocol + host + optional port)
#
# Local development — Vite proxies /api to this server, so the browser's
# origin is the Vite dev server (5173), not this server (3000).
RP_ID=localhost
RP_NAME=Ryder Kiosk
ORIGIN=http://localhost:5173

# ── Production example (HTTPS required for any non-localhost host) ────────────
# RP_ID=kiosk.ryder.com
# RP_NAME=Ryder Kiosk
# ORIGIN=https://kiosk.ryder.com

# ── Auth0 (enterprise sign-in) ────────────────────────────────────────────────
# These are read by the Vite frontend (VITE_ prefix required).
# Also register your app's origin in Auth0 → Applications → Allowed Callback URLs.
# Dev: add http://localhost:5173 to Allowed Callback URLs in the Auth0 dashboard.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
